		<name>activate</name>
		<handler>on_save_as_activate</handler>
		<last_modification_time>Sat, 15 Sep 2001 20:16:56 GMT</last_modification_time>
	      </signal>
	      <label>Save _As</label>
	      <right_justify>False</right_justify>
	    </widget>

	    <widget>
	      <class>GtkMenuItem</class>
	      <name>separator3</name>
	      <right_justify>False</right_justify>
	    </widget>

	    <widget>
	      <class>GtkMenuItem</class>
	      <name>exit</name>
	      <signal>
		<name>activate</name>
		<handler>on_quit</handler>
		<last_modification_time>Sat, 15 Sep 2001 20:16:56 GMT</last_modification_time>
	      </signal>
	      <label>E_xit</label>
	      <right_justify>False</right_justify>
