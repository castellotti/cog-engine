  <widget class="GtkWindow" id="direction_editor">
    <property name="title" translatable="yes">Direction Editor</property>
    <property name="type">GTK_WINDOW_TOPLEVEL</property>
    <property name="modal">no</property>
    <property name="default_width">600</property>
    <property name="default_height">430</property>
    <property name="allow_shrink">no</property>
    <property name="allow_grow">yes</property>
    <property name="window-position">GTK_WIN_POS_NONE</property>
    <property name="visible">yes</property>

    <signal name="destroy" handler="on_direction_editor_destroy" />

    <child>
      <widget class="GtkVBox" id="vbox40">
        <property name="homogeneous">no</property>
        <property name="spacing">0</property>
        <property name="visible">yes</property>

        <child>
          <widget class="GtkToolbar" id="toolbar17">
            <property name="border_width">1</property>
            <property name="orientation">GTK_ORIENTATION_HORIZONTAL</property>
            <property name="toolbar-style">GTK_TOOLBAR_BOTH</property>
            <property name="visible">yes</property>

            <child>
              <widget class="button" id="direction_editor_new_button">
                <property name="tooltip" translatable="yes">Click here to create a new direction</property>
                <property name="label" translatable="yes">New</property>
                <property name="icon">stock_new.xpm</property>
                <property name="visible">yes</property>

                <signal name="clicked" handler="on_direction_editor_new_button_clicked" />
              </widget>
            </child>

            <child>
              <widget class="button" id="direction_editor_first_button">
                <property name="tooltip" translatable="yes">Click here to cycle back to the first direction</property>
                <property name="label" translatable="yes">First</property>
                <property name="icon">stock_first.xpm</property>
                <property name="visible">yes</property>

                <signal name="clicked" handler="on_direction_editor_first_button_clicked" />
              </widget>
            </child>

            <child>
              <widget class="button" id="direction_editor_previous_button">
                <property name="tooltip" translatable="yes">Click here to cycle back to the previous direction</property>
                <property name="label" translatable="yes">Previous</property>
                <property name="icon">stock_left_arrow.xpm</property>
                <property name="visible">yes</property>

                <signal name="clicked" handler="on_direction_editor_previous_button_clicked" />
              </widget>
            </child>

            <child>
              <widget class="button" id="direction_editor_next_button">
                <property name="tooltip" translatable="yes">Click here to cycle forward to the next direction</property>
                <property name="label" translatable="yes">Next</property>
                <property name="icon">stock_right_arrow.xpm</property>
                <property name="visible">yes</property>

                <signal name="clicked" handler="on_direction_editor_next_button_clicked" />
              </widget>
            </child>

            <child>
              <widget class="button" id="direction_editor_last_button">
                <property name="tooltip" translatable="yes">Click here to cycle forward to the last direction</property>
                <property name="label" translatable="yes">Last</property>
                <property name="icon">stock_last.xpm</property>
                <property name="visible">yes</property>

                <signal name="clicked" handler="on_direction_editor_last_button_clicked" />
              </widget>
            </child>

            <child>
              <widget class="button" id="direction_editor_save_button">
                <property name="tooltip" translatable="yes">Click here to save the current direction's data</property>
                <property name="label" translatable="yes">Save</property>
                <property name="icon">stock_save.xpm</property>
                <property name="visible">yes</property>

                <signal name="clicked" handler="on_direction_editor_save_button_clicked" />
              </widget>
            </child>

            <child>
              <widget class="GtkVBox" id="vbox58">
                <property name="homogeneous">no</property>
                <property name="spacing">0</property>
                <property name="visible">yes</property>

                <child>
                  <widget class="GtkLabel" id="label89">
