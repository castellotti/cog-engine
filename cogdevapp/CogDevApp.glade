<?xml version="1.0" standalone="no"?> <!--*- mode: nxml -*-->
<!DOCTYPE glade-interface SYSTEM "http://glade.gnome.org/glade-2.0.dtd" >

<glade-interface>
  <widget class="GtkWindow" id="CogDevApp">
    <property name="title" translatable="yes">Cog Development Application</property>
    <property name="type">GTK_WINDOW_TOPLEVEL</property>
    <property name="modal">no</property>
    <property name="allow_shrink">no</property>
    <property name="allow_grow">no</property>
    <property name="window-position">GTK_WIN_POS_NONE</property>
    <property name="visible">yes</property>

    <signal name="destroy" handler="on_quit" />

    <child>
      <widget class="GtkVBox" id="vbox39">
        <property name="homogeneous">no</property>
        <property name="spacing">0</property>
        <property name="visible">yes</property>

        <child>
          <widget class="GtkHandleBox" id="handlebox7">
            <property name="handle_position">GTK_POS_LEFT</property>
            <property name="snap_edge">GTK_POS_TOP</property>
            <property name="shadow">GTK_SHADOW_OUT</property>
            <property name="visible">yes</property>

            <child>
              <widget class="GtkMenuBar" id="menubar3">
                <property name="visible">yes</property>

                <child>
                  <widget class="GtkMenuItem" id="file">
                    <property name="label" translatable="yes">_File</property>
                    <property name="visible">yes</property>
                    <property name="use_underline">yes</property>

                    <child>
                      <widget class="GtkMenu" id="file_menu">
                        <property name="visible">yes</property>

                        <child>
                          <widget class="GtkMenuItem" id="new_file">
                            <property name="label" translatable="yes">_New</property>
                            <property name="visible">yes</property>
                            <property name="use_underline">yes</property>

                            <signal name="activate" handler="on_new_file_activate" />
                          </widget>
                        </child>

                        <child>
                          <widget class="GtkMenuItem" id="open">
                            <property name="label" translatable="yes">_Open</property>
                            <property name="visible">yes</property>
                            <property name="use_underline">yes</property>

                            <signal name="activate" handler="on_open_activate" />
                          </widget>
                        </child>

                        <child>
                          <widget class="GtkMenuItem" id="save">
                            <property name="label" translatable="yes">_Save</property>
                            <property name="visible">yes</property>
                            <property name="use_underline">yes</property>

                            <signal name="activate" handler="on_save_activate" />
                          </widget>
                        </child>

                        <child>
                          <widget class="GtkMenuItem" id="save_as">
                            <property name="label" translatable="yes">Save _As</property>
                            <property name="visible">yes</property>
                            <property name="use_underline">yes</property>

                            <signal name="activate" handler="on_save_as_activate" />
                          </widget>
                        </child>

                        <child>
                          <widget class="GtkMenuItem" id="separator3">
                            <property name="visible">yes</property>
                          </widget>
                        </child>

                        <child>
                          <widget class="GtkMenuItem" id="exit">
                            <property name="label" translatable="yes">E_xit</property>
                            <property name="visible">yes</property>
                            <property name="use_underline">yes</property>

                            <signal name="activate" handler="on_quit" />
                          </widget>
                        </child>
                      </widget>
                    </child>
                  </widget>
                </child>

                <child>
                  <widget class="GtkMenuItem" id="help">
                    <property name="label" translatable="yes">_Help</property>
                    <property name="visible">yes</property>
                    <property name="use_underline">yes</property>

                    <child>
                      <widget class="GtkMenu" id="help_menu">
                        <property name="visible">yes</property>

                        <child>
                          <widget class="GtkMenuItem" id="about">
                            <property name="label" translatable="yes">_About</property>
                            <property name="visible">yes</property>
                            <property name="use_underline">yes</property>

                            <signal name="activate" handler="on_about_activate" />
                          </widget>
                        </child>
                      </widget>
                    </child>
                  </widget>
                </child>
              </widget>
            </child>
          </widget>
          <packing>
            <property name="padding">0</property>
            <property name="expand">yes</property>
            <property name="fill">yes</property>
          </packing>
        </child>

        <child>
          <widget class="GtkVBox" id="vbox1">
            <property name="border_width">8</property>
            <property name="homogeneous">yes</property>
            <property name="spacing">4</property>
            <property name="visible">yes</property>

            <child>
              <widget class="GtkToggleButton" id="game_information_togglebutton">
                <property name="tooltip" translatable="yes">The Game Information Editor is used to collect basic setup information about your game module</property>
                <property name="can_focus">yes</property>
                <property name="label" translatable="yes">Game Information</property>
                <property name="relief">GTK_RELIEF_NORMAL</property>
                <property name="active">no</property>
                <property name="visible">yes</property>

                <signal name="toggled" handler="on_game_information_togglebutton_toggled" />
              </widget>
              <packing>
                <property name="padding">0</property>
                <property name="expand">no</property>
                <property name="fill">no</property>
              </packing>
            </child>

            <child>
              <widget class="GtkToggleButton" id="player_information_togglebutton">
                <property name="tooltip" translatable="yes">The Playing Information Editor is used to configure the player's character at the start of a new game</property>
                <property name="can_focus">yes</property>
                <property name="label" translatable="yes">Player Information</property>
                <property name="relief">GTK_RELIEF_NORMAL</property>
                <property name="active">no</property>
                <property name="visible">yes</property>

                <signal name="toggled" handler="on_player_information_togglebutton_toggled" />
              </widget>
              <packing>
                <property name="padding">0</property>
                <property name="expand">no</property>
                <property name="fill">no</property>
              </packing>
            </child>

            <child>
              <widget class="GtkToggleButton" id="direction_togglebutton">
                <property name="tooltip" translatable="yes">The Direction Editor is used to set up each of the directions a player can travel from one room to another</property>
                <property name="can_focus">yes</property>
                <property name="label" translatable="yes">Directions</property>
                <property name="relief">GTK_RELIEF_NORMAL</property>
                <property name="active">no</property>
                <property name="visible">yes</property>

                <signal name="toggled" handler="on_direction_togglebutton_toggled" />
              </widget>
              <packing>
                <property name="padding">0</property>
                <property name="expand">no</property>
                <property name="fill">no</property>
              </packing>
            </child>

            <child>
              <widget class="GtkToggleButton" id="room_togglebutton">
                <property name="tooltip" translatable="yes">The Room Editor collects all of the information about each room in the game, how they interconnect, and which objects they contain</property>
                <property name="can_focus">yes</property>
                <property name="label" translatable="yes">Rooms</property>
                <property name="relief">GTK_RELIEF_NORMAL</property>
                <property name="active">no</property>
                <property name="visible">yes</property>

                <signal name="toggled" handler="on_room_togglebutton_toggled" />
              </widget>
              <packing>
                <property name="padding">0</property>
                <property name="expand">no</property>
                <property name="fill">no</property>
              </packing>
            </child>

            <child>
              <widget class="GtkToggleButton" id="item_togglebutton">
                <property name="tooltip" translatable="yes">The Item Editor configures all of the objects in the game which the player can manipulate and carry</property>
                <property name="can_focus">yes</property>
                <property name="label" translatable="yes">Items</property>
                <property name="relief">GTK_RELIEF_NORMAL</property>
                <property name="active">no</property>
                <property name="visible">yes</property>

                <signal name="toggled" handler="on_item_togglebutton_toggled" />
              </widget>
              <packing>
                <property name="padding">0</property>
                <property name="expand">no</property>
                <property name="fill">no</property>
              </packing>
            </child>

            <child>
              <widget class="GtkToggleButton" id="obstruction_togglebutton">
                <property name="tooltip" translatable="yes">The Obstruction Editor configures all of the obstacles which block a player's movement from one room to another</property>
                <property name="can_focus">yes</property>
                <property name="label" translatable="yes">Obstructions</property>
                <property name="relief">GTK_RELIEF_NORMAL</property>
                <property name="active">no</property>
                <property name="visible">yes</property>

                <signal name="toggled" handler="on_obstruction_togglebutton_toggled" />
              </widget>
              <packing>
                <property name="padding">0</property>
                <property name="expand">no</property>
                <property name="fill">no</property>
              </packing>
            </child>

            <child>
              <widget class="GtkToggleButton" id="verb_togglebutton">
                <property name="tooltip" translatable="yes">The Verb Editor configures all of the actions a player is able to take in your game</property>
                <property name="can_focus">yes</property>
                <property name="label" translatable="yes">Verbs (Actions)</property>
                <property name="relief">GTK_RELIEF_NORMAL</property>
                <property name="active">no</property>
                <property name="visible">yes</property>

                <signal name="toggled" handler="on_verb_togglebutton_toggled" />
              </widget>
              <packing>
                <property name="padding">0</property>
                <property name="expand">no</property>
                <property name="fill">no</property>
              </packing>
            </child>

            <child>
              <widget class="GtkToggleButton" id="event_togglebutton">
                <property name="tooltip" translatable="yes">The Event Editor ties together all of the interactions between the player and the game environment</property>
                <property name="can_focus">yes</property>
                <property name="label" translatable="yes">Events</property>
                <property name="relief">GTK_RELIEF_NORMAL</property>
                <property name="active">no</property>
                <property name="visible">yes</property>

                <signal name="toggled" handler="on_event_togglebutton_toggled" />
              </widget>
              <packing>
                <property name="padding">0</property>
                <property name="expand">no</property>
                <property name="fill">no</property>
              </packing>
            </child>
          </widget>
          <packing>
            <property name="padding">0</property>
            <property name="expand">yes</property>
            <property name="fill">yes</property>
          </packing>
        </child>

        <child>
          <widget class="GtkToggleButton" id="play_togglebutton">
            <property name="border_width">8</property>
            <property name="tooltip" translatable="yes">Click here to begin playing a Cog Engine game module</property>
            <property name="can_focus">yes</property>
            <property name="label" translatable="yes">Play!</property>
            <property name="relief">GTK_RELIEF_NORMAL</property>
            <property name="active">no</property>
            <property name="height-request">66</property>
            <property name="visible">yes</property>

            <signal name="toggled" handler="on_play_togglebutton_toggled" />
          </widget>
          <packing>
            <property name="padding">0</property>
            <property name="expand">no</property>
            <property name="fill">no</property>
          </packing>
        </child>
      </widget>
    </child>
  </widget>
  <widget class="GtkWindow" id="game_information_editor">
