<widget>
  <class>GtkWindow</class>
  <name>obstruction_editor</name>
  <signal>
    <name>destroy</name>
    <handler>on_obstruction_editor_destroy</handler>
    <last_modification_time>Sat, 15 Sep 2001 19:22:51 GMT</last_modification_time>
  </signal>
  <title>Obstruction Editor</title>
  <type>GTK_WINDOW_TOPLEVEL</type>
  <position>GTK_WIN_POS_NONE</position>
  <modal>False</modal>
  <default_width>600</default_width>
  <default_height>430</default_height>
  <allow_shrink>False</allow_shrink>
  <allow_grow>True</allow_grow>
  <auto_shrink>False</auto_shrink>

  <widget>
    <class>GtkVBox</class>
    <name>vbox43</name>
    <homogeneous>False</homogeneous>
    <spacing>0</spacing>

    <widget>
      <class>GtkToolbar</class>
      <name>toolbar15</name>
      <border_width>1</border_width>
      <orientation>GTK_ORIENTATION_HORIZONTAL</orientation>
      <type>GTK_TOOLBAR_BOTH</type>
      <space_size>16</space_size>
      <space_style>GTK_TOOLBAR_SPACE_LINE</space_style>
      <relief>GTK_RELIEF_NONE</relief>
      <tooltips>True</tooltips>
      <child>
	<padding>0</padding>
	<expand>False</expand>
	<fill>False</fill>
      </child>

      <widget>
	<class>GtkButton</class>
	<child_name>Toolbar:button</child_name>
	<name>obstruction_editor_new_button</name>
	<signal>
	  <name>clicked</name>
	  <handler>on_obstruction_editor_new_button_clicked</handler>
