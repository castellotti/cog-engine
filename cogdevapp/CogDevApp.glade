  <widget class="GtkWindow" id="obstruction_editor">
    <property name="title" translatable="yes">Obstruction Editor</property>
    <property name="type">GTK_WINDOW_TOPLEVEL</property>
    <property name="modal">no</property>
    <property name="default_width">600</property>
    <property name="default_height">430</property>
    <property name="allow_shrink">no</property>
    <property name="allow_grow">yes</property>
    <property name="window-position">GTK_WIN_POS_NONE</property>
    <property name="visible">yes</property>

    <signal name="destroy" handler="on_obstruction_editor_destroy" />

    <child>
      <widget class="GtkVBox" id="vbox43">
        <property name="homogeneous">no</property>
        <property name="spacing">0</property>
        <property name="visible">yes</property>

        <child>
          <widget class="GtkToolbar" id="toolbar15">
            <property name="border_width">1</property>
            <property name="orientation">GTK_ORIENTATION_HORIZONTAL</property>
            <property name="toolbar-style">GTK_TOOLBAR_BOTH</property>
            <property name="visible">yes</property>

            <child>
              <widget class="button" id="obstruction_editor_new_button">
                <property name="tooltip" translatable="yes">Click here to create a new obstruction</property>
                <property name="label" translatable="yes">New</property>
                <property name="icon">stock_new.xpm</property>
                <property name="visible">yes</property>

                <signal name="clicked" handler="on_obstruction_editor_new_button_clicked" />
              </widget>
            </child>

            <child>
              <widget class="button" id="obstruction_editor_first_button">
                <property name="tooltip" translatable="yes">Click here to cycle back to the first obstruction</property>
                <property name="label" translatable="yes">First</property>
                <property name="icon">stock_first.xpm</property>
                <property name="visible">yes</property>

                <signal name="clicked" handler="on_obstruction_editor_first_button_clicked" />
              </widget>
            </child>

            <child>
              <widget class="button" id="obstruction_editor_previous_button">
                <property name="tooltip" translatable="yes">Click here to cycle back to the previous obstruction</property>
                <property name="label" translatable="yes">Previous</property>
                <property name="icon">stock_left_arrow.xpm</property>
                <property name="visible">yes</property>

                <signal name="clicked" handler="on_obstruction_editor_previous_button_clicked" />
              </widget>
            </child>

            <child>
              <widget class="button" id="obstruction_editor_next_button">
                <property name="tooltip" translatable="yes">Click here to cycle forward to the next obstruction</property>
                <property name="label" translatable="yes">Next</property>
                <property name="icon">stock_right_arrow.xpm</property>
                <property name="visible">yes</property>

                <signal name="clicked" handler="on_obstruction_editor_next_button_clicked" />
              </widget>
            </child>

            <child>
              <widget class="button" id="obstruction_editor_last_button">
                <property name="tooltip" translatable="yes">Click here to cycle forward to the last obstruction</property>
                <property name="label" translatable="yes">Last</property>
                <property name="icon">stock_last.xpm</property>
                <property name="visible">yes</property>

                <signal name="clicked" handler="on_obstruction_editor_last_button_clicked" />
              </widget>
            </child>

            <child>
              <widget class="button" id="obstruction_editor_save_button">
                <property name="tooltip" translatable="yes">Click here to save the current obstruction's information</property>
                <property name="label" translatable="yes">Save</property>
                <property name="icon">stock_save.xpm</property>
                <property name="visible">yes</property>

                <signal name="clicked" handler="on_obstruction_editor_save_button_clicked" />
              </widget>
            </child>

            <child>
              <widget class="GtkVBox" id="vbox61">
                <property name="homogeneous">no</property>
                <property name="spacing">0</property>
                <property name="visible">yes</property>

                <child>
                  <widget class="GtkLabel" id="label87">
                    <property name="label" translatable="yes">Obstruction List:</property>
                    <property name="justify">GTK_JUSTIFY_CENTER</property>
                    <property name="wrap">no</property>
                    <property name="xalign">0.5</property>
                    <property name="yalign">0.5</property>
                    <property name="xpad">10</property>
                    <property name="ypad">0</property>
                    <property name="visible">yes</property>
                  </widget>
                  <packing>
                    <property name="padding">0</property>
                    <property name="expand">no</property>
                    <property name="fill">no</property>
                  </packing>
                </child>

                <child>
                  <widget class="GtkCombo" id="obstruction_editor_selection_combo">
                    <property name="value_in_list">no</property>
                    <property name="case_sensitive">no</property>
